<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
        <% if(blog && blog.length!== 0){ %>
     <%    blog?.forEach((data)=>{ %>
            <p><%= data.id %></p>
            <p><%= data.title%></p>
            <p><%= data.body%></p>
            
            <br>
           
     <%    }) %>
    <% } else { %>
        <p>no post found</p>
   <% } %>
</body>
</html>